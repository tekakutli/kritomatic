# ==============================================================================
# KRITOMATIC ENVIRONMENT CONFIGURATION
# ==============================================================================
# INSTALLATION:
# This file MUST be placed at: ~/.config/xremap/xremap_kritomatic.env
#
# PURPOSE:
# This file provides the local paths and device settings for the
# xremap-kritomatic systemd service.
# ==============================================================================

# 1. REPOSITORY PATH
# The absolute path to the directory where this repository is cloned.
REPODIR="/path/to/your/cloned/repo"

# 2. PERSONAL CONFIGURATION (OPTIONAL)
# Path to an additional personal xremap configuration file.
# LEAVE EMPTY ("") if you do not have a secondary config file.
PERSONAL_CONFIG=""

# 3. TARGET DEVICE (OPTIONAL)
# The hardware device name to target (e.g., "kanata ministeren").
# Run 'xremap --list-devices' to see available names.
# LEAVE EMPTY ("") to apply shortcuts to ALL connected input devices.
TARGET_DEVICE=""
